# === Muse AI 配置（可选） ===
# 不配置任何 API Key 时，所有 AI 能力自动降级为本地确定性 mock，闭环流程仍可完整跑通。

# AI 供应商：anthropic | openai | openai-compatible
MUSE_AI_PROVIDER=anthropic

# 模型 ID，例如 claude-sonnet-5 / gpt-4o / 任意兼容模型
MUSE_AI_MODEL=claude-sonnet-5

# 各供应商密钥（按 MUSE_AI_PROVIDER 二选一即可）
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# openai-compatible 供应商的自定义网关
MUSE_AI_BASE_URL=
MUSE_AI_API_KEY=

# === 数据 ===
# SQLite 数据库与上传文件默认存放在 ./data 下，可通过以下变量覆盖
# MUSE_DATA_DIR=./data

# === 发布 ===
# mock 发布器的失败概率（0~1，默认 0.1，用于演示失败重试）
# MUSE_MOCK_PUBLISH_FAIL_RATE=0.1
