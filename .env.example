# === Muse AI 配置 ===
# 把本文件复制为 .env.local 并填入密钥。
# 不配置任何 API Key 时，所有 AI 能力自动降级为本地确定性 mock，闭环流程仍可完整跑通。
# 配置后所有文本 AI 能力（清洗/选题/brief/初稿/改写/审阅/包装/平台版本/复盘反哺）走真实模型，
# 单次调用失败时自动降级 mock。AI 生图暂不支持：包装台只产出配图提示词，图片需外部工具生成后上传。

# AI 供应商：openai-compatible（默认，DeepSeek）| anthropic | openai
MUSE_AI_PROVIDER=openai-compatible

# openai-compatible 网关与密钥（DeepSeek 默认值）
MUSE_AI_BASE_URL=https://api.deepseek.com
MUSE_AI_MODEL=deepseek-v4-flash
MUSE_AI_API_KEY=

# 其他供应商密钥（切换 MUSE_AI_PROVIDER 时使用）
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# === 数据 ===
# SQLite 数据库与上传文件默认存放在 ./data 下，可通过以下变量覆盖
# MUSE_DATA_DIR=./data

# === 发布 ===
# mock 发布器的失败概率（0~1，默认 0.1，用于演示失败重试）
# MUSE_MOCK_PUBLISH_FAIL_RATE=0.1
